<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="ak_email_template_merge_order_lines" model="mail.template">
            <field name="name">Sale Order: Merged Order Lines Notification</field>
            <field name="model_id" ref="sale.model_sale_order"/>
            <field name="subject">Order lines have been merged in {{ object.name }}</field>
            <field name="email_to">{{ ','.join(object.company_id.notify_partner_ids.mapped('email')) }}</field>
            <field name="description">Notification sent to designated partners when order lines are merged in a sale order.</field>
            <field name="body_html" type="html">
                <div style="margin: 0px; padding: 0px;">
                    <p style="margin: 0px; padding: 0px; font-size: 13px;">
                        Hello,
                        <br/><br/>
                        Order lines have been merged in Quotation <strong><t t-out="object.name"></t></strong>.
                        <br/><br/>
                        Thank you.
                    </p>
                </div>
            </field>
            <field name="auto_delete" eval="True"/>
        </record>
    </data>
</odoo>
