<?xml version="1.0" encoding="UTF-8"?>
<templates id="template">
    <t t-name="ak_pos_reciept_customization.Orderline" t-inherit="point_of_sale.Orderline"
        t-inherit-mode="extension">
        <xpath expr="//ul[hasclass('info-list d-flex flex-column mb-0 ms-2')]" position="inside">
            <li t-if="vals.isReceipt and line.product_id.default_code">
                <t style="font-size: 75%;" t-esc="line.product_id.default_code" />
            </li>
        </xpath>
    </t>
</templates>