<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Navigation Breadcrumbs -->
    <template id="portal_my_home_menu_product_category"
        name="Portal layout : product category menu entries" inherit_id="portal.portal_breadcrumbs"
        priority="30">
        <xpath expr="//ol[hasclass('o_portal_submenu')]" position="inside">
            <li id="portal_breadcrumbs_product_category" t-if="page_name == 'product_category'"
                t-attf-class="breadcrumb-item #{'active ' if not category else ''}">
                <a t-if="category" t-attf-href="/my/product_categories?{{ keep_query() }}">Product
                    Categories</a>
                <t t-else="">Product Categories</t>
            </li>
            <li t-if="category" class="breadcrumb-item active">
                <t t-out="category.name" />
            </li>
        </xpath>
    </template>

    <!-- Portal Home Card -->
    <template id="portal_my_home_product_category" name="Product Categories" customize_show="True"
        inherit_id="portal.portal_my_home" priority="30">
        <xpath expr="//div[hasclass('o_portal_docs')]" position="before">
            <t t-set="portal_client_category_enable" t-value="True" />
        </xpath>
        <div id="portal_client_category" position="inside">
            <t t-call="portal.portal_docs_entry">
                <t t-set="title">Product Categories</t>
                <t t-set="url" t-value="'/my/product_categories'" />
                <t t-set="text">Access all your product categories</t>
                <t t-set="placeholder_count" t-value="'product_category_count'" />
            </t>
        </div>
    </template>

    <!-- List View -->
    <template id="portal_my_product_categories" name="My Product Categories">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True" />

            <t t-call="portal.portal_searchbar">
                <t t-set="title">Product Categories</t>
            </t>

            <div t-if="not categories" class="alert alert-warning" role="alert">
                There are currently no product categories available.
            </div>

            <t t-if="categories" t-call="portal.portal_table">
                <thead>
                    <tr class="active">
                        <th>Category Name</th>
                        <th>Parent Category</th>
                    </tr>
                </thead>
                <t t-foreach="categories" t-as="cat">
                    <tr>
                        <td>
                            <a t-attf-href="/my/product_category/#{cat.id}">
                                <t t-out="cat.name" />
                            </a>
                        </td>
                        <td>
                            <span t-field="cat.parent_id.name" />
                        </td>
                    </tr>
                </t>
            </t>
        </t>
    </template>

    <!-- Form View -->
    <template id="portal_product_category_form" name="Product Category Info">
        <t t-call="portal.portal_layout">
            <div class="card mt-3">
                <div class="card-header">
                    <h3 class="mb-0">Product Category: <t t-out="category.name" /></h3>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label>
                                <strong>Name:</strong>
                            </label>
                            <div t-field="category.name" />
                        </div>
                        <div class="col-md-6 mb-3" t-if="category.parent_id">
                            <label>
                                <strong>Parent Category:</strong>
                            </label>
                            <div t-field="category.parent_id.name" />
                        </div>
                    </div>
                </div>

                <div class="card-body border-top" t-if="products">
                    <h4>Products in this Category</h4>
                    <div class="table-responsive">
                        <table class="table table-striped table-hover">
                            <thead>
                                <tr>
                                    <th>Image</th>
                                    <th>Product Name</th>
                                    <th>Price</th>
                                    <th class="text-end">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="products" t-as="product">
                                    <tr>
                                        <td>
                                            <img
                                                t-attf-src="/web/image/product.template/#{product.id}/image_128"
                                                class="img-thumbnail" style="max-height: 50px;"
                                                alt="Product Image" />
                                        </td>
                                        <td class="align-middle">
                                            <a t-attf-href="/shop/product/#{product.id}">
                                                <t t-out="product.name" />
                                            </a>
                                        </td>
                                        <td class="align-middle">
                                            <span t-field="product.list_price"
                                                t-options='{"widget": "monetary", "display_currency": product.currency_id}' />
                                        </td>
                                        <td class="align-middle text-end">
                                            <form
                                                t-attf-action="/my/product_category/#{category.id}/remove_category/#{product.id}"
                                                method="POST">
                                                <input type="hidden" name="csrf_token"
                                                    t-att-value="request.csrf_token()" />
                                                <button type="submit" class="btn btn-sm btn-danger">
                                                    <i class="fa fa-times"></i> Remove </button>
                                            </form>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="card-footer text-end">
                    <a href="/my/product_categories" class="btn btn-secondary me-2">Back to
                        Categories</a>
                    <a t-attf-href="/shop/category/#{category.id}" class="btn btn-primary"
                        t-if="category">View Products in Shop</a>
                </div>
            </div>
        </t>
    </template>

</odoo>