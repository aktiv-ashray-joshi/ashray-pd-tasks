<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <t t-name="ak_pos_salesperson.SelectSalespersonButton">
        <button class="set-salesperson btn btn-secondary btn-lg text-overflow" t-on-click="() => this.clickSelectSalesperson()">
            <div t-if="salespersonName" t-esc="salespersonName" class="text-overflow text-action" />
            <t t-else="">Salesperson</t>
        </button>
    </t>

    <t t-name="ak_pos_salesperson.ControlButtons" t-inherit="point_of_sale.ControlButtons" t-inherit-mode="extension">
        <xpath expr="//InternalNoteButton" position="after">
            <t t-if="!props.showRemainingButtons || (ui.isSmall and props.showRemainingButtons)">
                <SelectSalespersonButton />
            </t>
        </xpath>
    </t>

    <t t-name="ak_pos_salesperson.PaymentScreenButtons" t-inherit="point_of_sale.PaymentScreenButtons" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('payment-buttons')]//button[hasclass('partner-button')]" position="after">
            <SelectSalespersonButton />
        </xpath>
    </t>

</templates>
