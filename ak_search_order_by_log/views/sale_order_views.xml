<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="sale_order_view_search_inherit_log_search" model="ir.ui.view">
        <field name="name">sale.order.search.inherit.log</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_sales_order_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//search" position="inside">
                <field name="message_ids" string="Log Note" filter_domain="[('message_ids.body', 'ilike', self)]"/>
            </xpath>
        </field>
    </record>
</odoo>
