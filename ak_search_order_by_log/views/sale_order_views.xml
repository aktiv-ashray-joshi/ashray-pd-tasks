<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="sale_order_view_search_inherit_log_search" model="ir.ui.view">
        <field name="name">sale.order.search.inherit.log</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_sales_order_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//search//field[@name='name']" position="replace">
                <field name="name" string="Order"
                    filter_domain="['|', '|', '|', ('name', 'ilike', self), ('client_order_ref', 'ilike', self), ('partner_id', 'child_of', self), ('message_ids.body','ilike',self)]" />
            </xpath>
        </field>
    </record>
</odoo>
