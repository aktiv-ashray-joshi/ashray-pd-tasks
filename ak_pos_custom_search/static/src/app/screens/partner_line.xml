<?xml version="1.0" encoding="UTF-8"?>
<templates id="template">
    <t t-name="ak_pos_custom_search.PartnerLine" t-inherit="point_of_sale.PartnerLine"
        t-inherit-mode="extension">

        <!-- For SMALL screens (div-based) -->
        <xpath expr="//div[hasclass('partner-line-email')]" position="before">
            <div class="partner-line-code p-1" t-if="props.partner.ak_customer_code">
                <span class="ms-2" t-esc="props.partner.ak_customer_code" />
            </div>
        </xpath>

        <!-- For LARGE screens (table-based) -->
        <xpath expr="//td[hasclass('partner-line-email')]" position="before">
            <td class="partner-line-code  text-break w-50">
                <div t-if="props.partner.ak_customer_code">
                    <div t-esc="props.partner.ak_customer_code" />
                </div>
            </td>
        </xpath>

    </t>
</templates>
