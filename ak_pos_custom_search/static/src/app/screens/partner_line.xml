<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="ak_pos_custom_search.PartnerLine" t-inherit="point_of_sale.PartnerLine" t-inherit-mode="extension">

        <xpath expr="//div[hasclass('partner-line-email') and hasclass('p-1')]" position="before">
            <div t-if="props.partner.ak_customer_code">
                <span class="text-break">Customer Code: <t t-esc="props.partner.ak_customer_code"/></span>
            </div>
        </xpath>

        <xpath expr="//td[hasclass('partner-line-email')]" position="before">
            <td class="align-middle">
                <div t-if="props.partner.ak_customer_code" class="d-flex align-items-center">
                    <div style="font-size:0.85em; font-weight:bold;">
                       Customer Code: <t t-esc="props.partner.ak_customer_code"/>
                    </div>
                </div>
            </td>
        </xpath>

    </t>
</templates>