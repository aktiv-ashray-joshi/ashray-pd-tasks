<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="sale_order_form_view_inherit_ak_stock_location_selection" model="ir.ui.view">
        <field name="name">sale.order.view.form.inherit.ak.stock.location</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form" />
        <field name="arch" type="xml">
            <xpath expr="//page//field[@name='order_line']/list/field[@name='tax_ids']" position="after">
                <field name="available_location_ids" column_invisible="1" />
                <field
                    name="location_id"
                    optional="show"
                    options="{'no_create': True, 'no_open': True}"
                    context="{'show_available_qty': True, 'product_id': product_id}"/>
            </xpath>
        </field>
    </record>

</odoo>
